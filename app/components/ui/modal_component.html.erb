<div
  data-controller="modal"
  id="<%= modal_id %>-root"
  <%= tag.attributes(html_options.except(:class)) %>
>
  <% if trigger %>
    <div class="inline-block"><%= trigger %></div>
  <% end %>

  <div
    data-modal-target="backdrop"
    class="hidden fixed inset-0 z-40 bg-secondary-900/40"
    data-action="click->modal#close"
    aria-hidden="true"
  ></div>

  <div
    data-modal-target="panel"
    class="hidden fixed left-1/2 top-1/2 z-50 w-full max-w-lg -translate-x-1/2 -translate-y-1/2 rounded-xl border border-secondary-200 bg-white p-6 shadow-dropdown"
    role="dialog"
    aria-modal="true"
    aria-labelledby="<%= modal_id %>-title"
  >
    <div class="mb-4 flex items-start justify-between gap-4">
      <h2 id="<%= modal_id %>-title" class="text-lg font-semibold text-secondary-900"><%= title %></h2>
      <button
        type="button"
        class="rounded-md p-1 text-secondary-500 hover:bg-secondary-100 hover:text-secondary-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500"
        data-action="click->modal#close"
        aria-label="Close dialog"
      >
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
    <div class="text-secondary-700">
      <%= content %>
    </div>
  </div>
</div>

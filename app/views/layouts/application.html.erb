<!DOCTYPE html>
<html>
  <head>
    <title>OnlineRetailShop</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <!-- Navigation Links within the format controller -->
  <body class="bg-gray-50 min-h-screen">
    <%= render Ui::NavbarComponent.new do %>
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center space-x-4">
          <%= render Ui::LinkButtonComponent.new(
                href: root_path,
                label: "Home",
                variant: :ghost,
                class: "shadow-none !px-3 !py-2 font-medium text-secondary-700 hover:text-primary-700"
              ) %>
          <%= render Ui::LinkButtonComponent.new(
                href: shopping_path,
                label: "Shopping",
                variant: :ghost,
                class: "shadow-none !px-3 !py-2 font-medium text-secondary-700 hover:text-primary-700"
              ) %>
        </div>
        <div class="flex items-center space-x-4">
          <% unless logged_in? %>
            <%= render Ui::LinkButtonComponent.new(
                  href: login_path,
                  label: "Login",
                  variant: :ghost,
                  class: "shadow-none !px-3 !py-2 font-medium text-secondary-700 hover:text-primary-700"
                ) %>
          <% else %>
            <%= render Ui::LinkButtonComponent.new(
                  href: logout_path,
                  label: "Logout",
                  variant: :danger,
                  method: :delete,
                  class: "!text-white"
                ) %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% flash.each do |key, message| %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <%= render Ui::AlertComponent.new(
              message: message,
              variant: ui_flash_variant(key),
              dismissible: false
            ) %>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
